{
  "manifest_version": 3,
  "name": "Purefusion TorrentBridge",
  "version": "2.1.0",
  "version_name": "2.1.0 – Power User Edition",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "offline_enabled": true,
  "incognito": "spanning",
  "icons": {
    "32": "icon/icon_32.png",
    "48": "icon/icon_48.png",
    "64": "icon/icon_64.png",
    "128": "icon/icon_128.png"
  },
  "action": {
    "default_icon": {
      "32": "icon/icon_32.png",
      "48": "icon/icon_48.png",
      "64": "icon/icon_64.png"
    },
    "default_title": "__MSG_extensionTitle__",
    "default_popup": "view/popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "contextMenus",
    "notifications",
    "storage"
  ],
  "optional_permissions": [
    "clipboardRead"
  ],
  "host_permissions": [],
  "optional_host_permissions": [
    "http://*/",
    "https://*/"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "view/options.html",
    "open_in_tab": true
  },
  "commands": {
    "add-from-clipboard": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Add magnet/torrent URL from clipboard"
    }
  }
}
